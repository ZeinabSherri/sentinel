# ─────────────────────────────────────────────
# Sentinel — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env.local for local dev.
# Never commit .env.local to source control.

# PostgreSQL connection string
# For Docker Compose: postgresql://sentinel:sentinel_secret@localhost:5432/sentinel
DATABASE_URL=postgresql://sentinel:sentinel_secret@localhost:5432/sentinel

# Redis connection string
# For Docker Compose: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# NextAuth — REQUIRED
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here-change-me
NEXTAUTH_URL=http://localhost:3000

# Anthropic API Key — REQUIRED for evaluations
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Background worker authentication secret
# Must match X-Worker-Secret header sent to /api/workers/evaluate
WORKER_SECRET=worker-secret-change-me

# Optional: Slack webhook for FAIL alerts
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Optional: Email provider for magic link auth (future)
# EMAIL_SERVER=smtp://user:pass@smtp.example.com:587
# EMAIL_FROM=noreply@example.com
